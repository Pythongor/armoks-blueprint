{
  "name": "armoks-blueprint",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "author": "Pythongor",
  "license": "MIT",
  "description": "A map-painting utility for Dwarf Fortress world generation.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pythongor/armoks-blueprint.git"
  },
  "bugs": {
    "url": "https://github.com/Pythongor/armoks-blueprint/issues"
  },
  "homepage": "https://Pythongor.github.io/armoks-blueprint",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "check-types": "tsc --noEmit",
    "verify": "npm run check-types && npm run lint && npm run build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "^2.5.1",
    "jszip": "^3.10.1",
    "phaser": "^3.90.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
